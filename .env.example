# poke-conduit env. NONE of these are needed for `npm test` / `npm run demo`.

# Real Claude for the council (omit → deterministic MockModel)
ANTHROPIC_API_KEY=
POKE_CONDUIT_PERSONA_MODEL=claude-haiku-4-5-20251001
POKE_CONDUIT_SYNTH_MODEL=claude-fable-5

# Neon Postgres (omit → in-memory pg-mem). Tables are pc_-prefixed; safe to
# share the existing poke-amb-bridge database.
DATABASE_URL=

# OUTBOUND proactive pushes: your Poke V2 API key (from poke.com/kitchen)
POKE_API_KEY=
POKE_INBOUND_URL=https://poke.com/api/v1/inbound/api-message

# INBOUND MCP auth (Poke → conduit)
MCP_AUTH_ENFORCE=false
MCP_BEARER_KEY=

# Inngest Cloud (prod durability/scheduler). Local Dev Server needs neither.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

PORT=7411
